# Terminal toolchain — installed via `brew bundle`

# Shell / prompt
brew "zsh-syntax-highlighting"
brew "zsh-autosuggestions"

# CLI tools used by .zshrc / aliases
brew "eza"        # better ls
brew "bat"        # better cat
brew "ripgrep"    # better grep (rg)
brew "fd"         # better find
brew "fzf"        # fuzzy finder
brew "zoxide"     # smart cd
brew "lazygit"    # git TUI
brew "btop"       # better top
brew "git-delta"  # git diff pager

# Terminal emulator + font
cask "kitty"
cask "font-fira-code-nerd-font"
